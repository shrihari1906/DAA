#include <iostream> 
using namespace std; 
int main() { 
int arr[5] = {2, 4, 6, 8, 10}; 
int key, low = 0, high = 4, mid; 
cout << "enter number to search: "; 
cin >> key; 
while (low <= high) { 
mid = (low + high) / 2; 
if (arr[mid] == key) { 
cout << "element found at position " << mid; 
return 0; 
} 
else if (arr[mid] < key) { 
low = mid + 1; 
} 
else { 
high = mid - 1; 
} 
} 
cout << "Element not found"; 
return 0; 
}
